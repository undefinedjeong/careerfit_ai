# frontend/Dockerfile

# 1단계: 빌드 환경
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# 2단계: 실행 환경 (Nginx)
FROM nginx:alpine
# 빌드된 정적 파일을 Nginx의 서빙 디렉토리로 복사
COPY --from=builder /app/dist /usr/share/nginx/html

# SPA(React) 라우팅을 위한 Nginx 설정 파일을 커스텀해서 사용해야 할 경우
# 아래와 같이 설정을 추가할 수 있습니다 (필요 시 default.conf 생성)
# COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]